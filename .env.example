<!-- .env.example -->
# TubeFlow Pro Configuration

# Server Settings
FLASK_ENV=development
DEBUG=True
SECRET_KEY=change-this-in-production-to-random-string
HOST=0.0.0.0
PORT=5001

# Security
REQUIRE_AUTH=False
API_KEY=your-api-key-here
MAX_REQUESTS_PER_MINUTE=60
BLOCK_THRESHOLD=100

# Download Settings
DOWNLOAD_FOLDER=downloads
MAX_FILE_SIZE=17179869184
CLEANUP_INTERVAL=300
CLEANUP_MAX_AGE=3600

# Cache Settings
CACHE_ENABLED=True
CACHE_MAX_SIZE=1000
CACHE_TTL=3600
CACHE_DISK=True

# Queue Settings
MAX_WORKERS=3
QUEUE_MAX_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_TO_CONSOLE=True
LOG_FORMAT=detailed